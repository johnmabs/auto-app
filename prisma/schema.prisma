generator client {
  provider = "prisma-client"
  output   = "../src/lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────
enum VehicleStatus {
  AVAILABLE // Disponible en stock
  TRANSIT // En transit / en cours d'importation
  RESERVED // Réservé par un client
  SOLD // Vendu
  DRAFT // Brouillon (non publié)
}

enum FuelType {
  GASOLINE // Essence
  DIESEL
  ELECTRIC
  HYBRID
  PLUGIN_HYBRID
  HYDROGEN
}

enum TransmissionType {
  AUTOMATIC
  MANUAL
  CVT
  DCT // Double embrayage
  PDK // Porsche PDK
}

enum VehicleType {
  SUV
  SEDAN
  COUPE
  PICKUP
  MINIVAN
  CONVERTIBLE
  WAGON
  HATCHBACK
  LUXURY
  SPORT
}

enum Country {
  CHINA
  DUBAI
  JAPAN
  GERMANY
  FRANCE
  SOUTH_KOREA
  USA
  EUROPE
}

enum RequestStatus {
  NEW
  CONTACTED
  IN_PROGRESS
  QUOTE_SENT
  CONFIRMED
  DELIVERED
  CANCELLED
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
}

// ─── Auth / Utilisateurs ───────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String // Hash bcrypt
  role          UserRole  @default(ADMIN)
  isActive      Boolean   @default(true)

  // Relations
  accounts Account[]
  sessions Session[]
  vehicles Vehicle[]
  requests CustomerRequest[]

  // Audit
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?
  deletedAt   DateTime?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Modèles principaux ────────────────────────────────────
model VehicleImage {
  id        String  @id @default(cuid())
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  url       String // URL Cloudinary
  publicId  String // Cloudinary public_id pour suppression
  alt       String?
  width     Int?
  height    Int?
  order     Int     @default(0)
  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([vehicleId, order])
  @@map("vehicle_images")
}

model CustomerRequest {
  id String @id @default(cuid())

  // Client
  firstName String
  lastName  String
  email     String
  phone     String
  country   String? // Pays du client
  city      String?

  // Demande
  message          String   @db.Text
  vehicleId        String? // Véhicule spécifique ou null (demande générale)
  vehicle          Vehicle? @relation(fields: [vehicleId], references: [id])
  desiredMake      String? // Si demande personnalisée
  desiredModel     String?
  budget           Int? // Budget max en USD
  preferredCountry Country? // Pays d'importation préféré

  // Traitement
  status     RequestStatus @default(NEW)
  adminNotes String?       @db.Text
  assignedTo String?
  assignee   User?         @relation(fields: [assignedTo], references: [id])

  // Audit
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  contactedAt DateTime?
  resolvedAt  DateTime?
  deletedAt   DateTime?

  // Source
  source   String? // "whatsapp", "form", "phone"
  referrer String? // URL de référence

  @@index([status])
  @@index([createdAt])
  @@index([email])
  @@map("customer_requests")
}

model Vehicle {
  id   String @id @default(cuid())
  slug String @unique

  // Identité
  make    String // Marque (BMW, Toyota...)
  model   String // Modèle (X7, Land Cruiser...)
  variant String? // Version/trim (M50i, Autobiography...)
  year    Int
  type    VehicleType

  // Caractéristiques techniques
  engine        String? // "4.4L V8 Biturbo"
  power         Int? // en chevaux
  torque        Int? // en Nm
  fuelType      FuelType
  transmission  TransmissionType
  mileage       Int // en km
  color         String
  interiorColor String?
  doors         Int              @default(4)
  seats         Int              @default(5)

  // Performance
  acceleration Float? // 0-100 km/h en secondes
  topSpeed     Int? // km/h
  consumption  Float? // L/100km ou kWh/100km
  autonomy     Int? // km (pour électriques)

  // Prix & Stock
  price           Int // en USD
  priceNegotiable Boolean       @default(false)
  comparePrice    Int? // Prix de référence barré
  status          VehicleStatus @default(DRAFT)
  stock           Int           @default(1)

  // Importation
  originCountry  Country
  importDate     DateTime?
  customsCleared Boolean   @default(false)
  chassisNumber  String?   @unique

  // Contenu
  description String?  @db.Text
  features    String[] // Liste des équipements
  isFeatured  Boolean  @default(false)
  isPopular   Boolean  @default(false)

  // SEO
  metaTitle       String?
  metaDescription String?

  // Relations
  images   VehicleImage[]
  requests CustomerRequest[]

  // Audit
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?
  deletedAt   DateTime?
  createdById String?
  createdBy   User?     @relation(fields: [createdById], references: [id])

  @@index([status, isFeatured])
  @@index([originCountry])
  @@index([make, model])
  @@index([price])
  @@index([year])
  @@map("vehicles")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String // "create_vehicle", "delete_vehicle", etc.
  entity    String // "Vehicle", "User", etc.
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
